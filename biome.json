{
	"$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": ["**", "!**/*.css", "!**/*.svelte", "!.svelte-kit/**", "!build/**", "!node_modules/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": { "organizeImports": { "level": "on" } }
		}
	},
	"javascript": {
		"formatter": { "quoteStyle": "single", "semicolons": "always" }
	}
}
